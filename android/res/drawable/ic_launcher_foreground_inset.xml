<?xml version="1.0" encoding="utf-8"?>
<!--
  Android adaptive layers are 108×108 dp; the “safe zone” is a 66 dp diameter
  circle (Material / adaptive-icon spec), so uniform margin is (108−66)/2 = 21 dp
  per edge → 21/108 ≈ 19.44% of the layer width.

  Reference: https://developer.android.com/develop/ui/views/launch/icon_design_adaptive
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/icon"
    android:insetLeft="19.44%"
    android:insetTop="19.44%"
    android:insetRight="19.44%"
    android:insetBottom="19.44%" />

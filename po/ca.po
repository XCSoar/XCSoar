#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:80
#, no-c-format
msgid "Bottom right (avoid InfoBoxes)"
msgstr "Dret inferior (evitar InfoBoxes)"

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:60
#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:98
#, no-c-format
msgid "Center top (avoid InfoBoxes)"
msgstr "Mapa i caselles d'informació"

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:62
#, no-c-format
msgid "Center bottom (avoid InfoBoxes)"
msgstr "Infer mitja (evitar InfoBoxes)"

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:69
#, no-c-format
msgid "Disable thermal assistant."
msgstr "Desactiva l'assistent termic."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:72
#, no-c-format
msgid "Show thermal assistant in bottom left."
msgstr "Mostra l'assistent termic a l'esquerra inferior."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:75
#, no-c-format
msgid ""
"Show thermal assistant in bottom left, above or to the right of InfoBoxes "
"(if present)."
msgstr ""
"Mostra l'assistent termic a l'esquerra inferior, encima o a la dreta de les "
"InfoBoxes (si estan presentes)."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:78
#, no-c-format
msgid "Show thermal assistant in bottom right."
msgstr "Mostra l'assistent termic a la dreta inferior."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:81
#, no-c-format
msgid ""
"Show thermal assistant in bottom right, above or to the left of InfoBoxes "
"(if present)."
msgstr ""
"Mostra l'assistent termic a la dreta inferior, encima o a la esquerra de les"
" InfoBoxes (si estan presentes)."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:84
#, no-c-format
msgid "Show thermal assistant in top left."
msgstr "Assistent de tèrmica"

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:87
#, no-c-format
msgid "Show thermal assistant in top right."
msgstr "Assistent de tèrmica"

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:90
#, no-c-format

"by a connected intelligent variometer."
msgstr ""
"Relativna vlaga vzdušja v procentih, merjena z vrteljem, če je podprta "
"povezanim inteligentnim variometerjem."

#: src/InfoBoxes/Content/Factory.cpp:529
#, no-c-format
msgid "Max Temp"
msgstr "Maksimalna temperatura"

#: src/InfoBoxes/Content/Factory.cpp:530
#, no-c-format

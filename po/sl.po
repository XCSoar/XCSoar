msgstr ""
"Premikajoči zemljevid bo obrnjen tako, da se smer gliderske premakne v smeri"
" vzpona."

#: src/Dialogs/Settings/Panels/MapDisplayConfigPanel.cpp:29
#, no-c-format
msgid ""
"The moving map display will always be orientated north to south and the "
"glider icon will be rotated to show its course."
msgstr ""
"Premikajoči zemljevid bo vedno orientovan proti severu in gliderska ikona bo"
" obrnjena, da prikazuje njegov trajek."

#: src/Dialogs/Settings/Panels/MapDisplayConfigPanel.cpp:30
#, no-c-format

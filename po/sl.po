msgid ""
"Enables the automatic starting and stopping of logger on takeoff and landing"
" respectively. Disable when flying paragliders."
msgstr ""
"Izklopi avtomatsko vklopljanje in izklopljanje loggerja pri vzletnih in "
"pristajalnih. Izklopi, če se premikajo s paraglidami."

#: src/Dialogs/Settings/Panels/LoggerConfigPanel.cpp:88
msgid "NMEA logger"
msgstr "NMEA zapisovalec"

#: src/Dialogs/Settings/Panels/LoggerConfigPanel.cpp:89

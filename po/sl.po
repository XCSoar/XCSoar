#: src/Task/TypeStrings.cpp:32
#, no-c-format
msgid ""
"FAI rules, allows only FAI start, finish and turn point types, for badges "
"and records. Enables FAI finish height for final glide calculation."
msgstr ""
"FAI pravila, dovoljeni so le FAI start, cilj in tipi obratni točk, za značke"
" in rekorde. Omogoči FAI ciljno višino za računar zadnjega doleta."

#: src/Task/TypeStrings.cpp:34
#, no-c-format
msgid "FAI rules, path from a start to two turn points and return."
msgstr "FAI pravila, pot od starta do dveh točk in povratek."

#: src/Task/TypeStrings.cpp:35
#, no-c-format
msgid "FAI rules, path from start to a single turn point and return."
msgstr "FAI pravila, pot od starta do ene obratne točke in povratek."

#: src/Task/TypeStrings.cpp:36
#, no-c-format
msgid "FAI rules, path from start to a goal destination."
msgstr "FAI pravila, pot od starta do cilja."

#: src/Task/TypeStrings.cpp:37
#, no-c-format
msgid ""
"Racing task around turn points. Can also be used for FAI badge and record "
"tasks. Allows all shapes of observation zones."
msgstr ""
"Dirkalna naloga okoli obratnih točk. Lahko se uporabi tudi za FAI značke in "
"rekorde. Dovoljene so vse oblike območij opazovanja."

#: src/Task/TypeStrings.cpp:39
#, no-c-format
msgid ""
"Task through assigned areas, minimum task time applies. Restricted to "
"cylinder and sector observation zones."
msgstr ""
"Naloga skozi določena območja, velja minimalni čas naloge. Opazovalna "
"območja omejena na cilindre in sektorje."

#: src/Task/TypeStrings.cpp:41
#, no-c-format
msgid ""
"Modified area task. Task with start, finish and at least one predefined 1 "
"mile cylinder. Pilot can add additional points as needed. Minimum task time "
"applies."
msgstr ""
"Naloga s prilagojenimi območji. Naloga s startom, ciljem, in najmanj enim "
"določenim 1-miljskim cilindrom. Pilot lahko po potrebi doda dodatne točke. "
"Velja minimalni čas naloge."

#: src/Task/TypeStrings.cpp:42
#, no-c-format
msgid ""
"Racing task with a mix of assigned areas and turn points, minimum task time "
"applies."
msgstr ""
"Dirkalna naloga z mešanico določenih območij in obratnih točk, velja "
"minimalni čas naloge."

#: src/Task/TypeStrings.cpp:43
#, no-c-format
msgid ""
"Casual touring task, uses start and finish cylinders and FAI sector turn "
"points."
msgstr ""
"Vsakdanja potovalna naloga, uporablja se startni in ciljni cilinder ter FAI "
"sektor za obratne točke."

#: src/Task/TypeStrings.cpp:56
#, no-c-format
msgid ""
"A 90-degree sector with 1 km radius. Cross corner edge from inside area to "
"start."
msgstr ""
"90 stopinjski sektor z polmerom 1 km. Prečkaj krak iz notranjosti sektorja "
"za start."

#: src/Task/TypeStrings.cpp:57
#, no-c-format
msgid ""
"A straight line start gate. Cross start gate from inside area to start."
msgstr "Ravna startna črta. Začni iz območja za start, da začneš nalogo."

#: src/Task/TypeStrings.cpp:58
#, no-c-format
msgid "A cylinder. Exit area to start."
msgstr "Cilinder. Zapusti njegovo območje za start."

#: src/Task/TypeStrings.cpp:59
#, no-c-format
msgid ""
"A 90-degree sector with 'infinite' length sides. Cross any edge, scored from"
" corner point."
msgstr ""
"90 stopinjski sektor z neskončnimi stranicami. Prečkaj kateri koli rob "
"selektorja, točkuje se kot sektorja."

#: src/Task/TypeStrings.cpp:61
#, no-c-format
msgid "A keyhole. Scored from center."
msgstr "Ključavnica. Točkuje se najbolj oddaljena točka dosežena v območju."

#: src/Task/TypeStrings.cpp:62
#, no-c-format
msgid ""
"(German rules) Any point within 1/2 km of center or 10 km of a 90-degree "
"sector. Scored from center."
msgstr ""
"(Nemška pravila) Katera koli točka v razdalji 0,5 km od centra ali pa točka "
"v 90 stopinjskem, 10 km dolgem sektorju. Točkuje se center."

#: src/Task/TypeStrings.cpp:64
#, no-c-format
msgid ""
"(British rules) Any point within 1/2 km of center or 20 km of a 90-degree "
"sector. Scored from center."
msgstr ""
"(Britanska pravila) Katera koli točka 0,5 km od centra ali točka v 90 "
"stopinjskem 20 km sektorju. Točkuje se center."

#: src/Task/TypeStrings.cpp:66
#, no-c-format
msgid ""
"(British rules) Any point within 1/2 km of center or 10 km of a 180-degree "
"sector. Scored from center."
msgstr ""
"(Britanska pravila) Katera koli točka v 0,5 km okoli centra ali 10 km 180 "
"stopinjski sektor. Točkuje se center."

#: src/Task/TypeStrings.cpp:68
#, no-c-format
msgid "A cylinder. Any point within area scored from center."
msgstr "Cilinder. Katera koli točka v površini cilindra. Točkuje se center."

#: src/Task/TypeStrings.cpp:69
#, no-c-format
msgid "A 1 mile cylinder. Scored by farthest point reached in area."
msgstr "Cilinder z r. 1 milje. Točkuje se najbolj oddaljena točka v površini."

#: src/Task/TypeStrings.cpp:70
#, no-c-format
msgid "A cylinder. Scored by farthest point reached in area."
msgstr "Cilinder. Točkuje se najbolj oddaljena točka dosežena v površini."

#: src/Task/TypeStrings.cpp:71
#, no-c-format
msgid ""
"A sector that can vary in angle and radius. Scored by farthest point reached"
" inside area."
msgstr ""
"Sektor z različnimi koti in polmeri. Točkuje se najbolj oddaljena točka "
"dosežena v površini."

#: src/Task/TypeStrings.cpp:73
#, no-c-format
msgid "A 90-degree sector with 1 km radius. Cross edge to finish."
msgstr "90 stopinjski sektor z radijem 1 km. Prečkaj rob za cilj."

#: src/Task/TypeStrings.cpp:74
#, no-c-format
msgid "Cross finish gate line into area to finish."
msgstr "Prečkaj ciljna vrata v območje za finiš."

#: src/Task/TypeStrings.cpp:75
#, no-c-format
msgid "Enter cylinder to finish."
msgstr "Vstopi v cilinder za dosego cilja."

#: src/Task/TypeStrings.cpp:76
#, no-c-format
msgid ""
"A 180-degree sector with 5 km radius. Exit area in any direction to start."
msgstr ""
"180 stopinjski sektor z polmerom 5 km. Zapusti območje v kateri koli smeri "
"za start."

#: src/Task/TypeStrings.cpp:77
#, no-c-format
msgid ""
"A sector that can vary in angle, inner and outer radius. Scored by farthest "
"point reached inside area."
msgstr ""
"Sektor z različnimi koti, notranjimi in zunanjimi polmeri. Točkuje se "
"najbolj oddaljena točka dosežena znotraj območja."

#: src/Task/TypeStrings.cpp:79
#, no-c-format
msgid "A symmetric quadrant with a custom radius."
msgstr "Simetrični kvadrant s poljubnim polmerom."

#: src/Task/TypeStrings.cpp:80
#, no-c-format
msgid "A keyhole. Scored by farthest point reached in area."
msgstr "Ključavnica. Točkuje se najbolj oddaljena točka dosežena v območju."


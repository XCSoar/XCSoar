msgstr "Prikaži pomoci pri termikah v spodnjem desnem kotu."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:81
#, no-c-format
msgid ""
"Show thermal assistant in bottom right, above or to the left of InfoBoxes "
"(if present)."
msgstr ""
"Prikaži pomoč terma v doljem desnem kotu, zgoraj ali levo od InfoBox-jev (če"
" so prikazani)."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:84
#, no-c-format

msgstr "Nome del pilota in comando, registrato nel registro di volo IGC."

#: src/Dialogs/Settings/Panels/LoggerConfigPanel.cpp:61
msgid "CoPilot name"
msgstr "Nome CoPilota"

#: src/Dialogs/Settings/Panels/LoggerConfigPanel.cpp:62

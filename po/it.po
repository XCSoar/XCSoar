msgstr ""
"Raggio o larghezza porta della zona di arrivo predefiniti per i nuovi temi."

#: src/Dialogs/Settings/Panels/TaskDefaultsConfigPanel.cpp:150
msgid "Turn point"
msgstr "Boa"

#: src/Dialogs/Settings/Panels/TaskDefaultsConfigPanel.cpp:150

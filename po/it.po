msgstr "Determina quanto lunga verrà visualizzata la scia del velivolo."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:157
msgid "Trail type"
msgstr "Tipo di scia"

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:158

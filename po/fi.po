msgstr "Valitse sääntöjä käytettäväksi optimointipisteiden laskennassa."

#: src/Dialogs/Settings/Panels/ScoringConfigPanel.cpp:122
msgid "Predict Contest"
msgstr "Edistämisnäkymä"


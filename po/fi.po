#: src/Dialogs/Task/Widgets/LineSectorZoneEditWidget.cpp:22
#: src/Dialogs/Task/dlgTaskHelpers.cpp:171
#, no-c-format
msgid "Gate width"
msgstr "Puolustusleveys"


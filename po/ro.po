msgstr "Stil introduceri de text"

#: src/Dialogs/Settings/Panels/InterfaceConfigPanel.cpp:161
msgid ""
"Determines how the user is prompted for text input (filename, teamcode etc.)"
msgstr ""
"Determină cum este promptat utilizatorul pentru introducerea de text (nume "
"fișier, cod echipă etc.)"


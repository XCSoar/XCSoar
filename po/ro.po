msgstr "Harta (de sus)"

#: src/Dialogs/Settings/Panels/PagesConfigPanel.cpp:181
msgid "Main area"
msgstr "Zona principală"

#: src/Dialogs/Settings/Panels/PagesConfigPanel.cpp:182

#: src/Dialogs/Settings/Panels/TerrainDisplayConfigPanel.cpp:283
msgid ""
"Defines the amount of Phong shading in the terrain rendering. Use large "
"values to emphasise terrain slope, smaller values if flying in steep "
"mountains."
msgstr ""
"Definiți cantitatea de shading Phong în renderizarea reliefului. Folosiți "
"valori mari pentru a evidenția pantele reliefului, valori mici dacă zborul "
"se face în munții înclinate."

#: src/Dialogs/Settings/Panels/TerrainDisplayConfigPanel.cpp:289
msgid "Terrain brightness"
msgstr "Lumină a reliefului"

#: src/Dialogs/Settings/Panels/TerrainDisplayConfigPanel.cpp:290

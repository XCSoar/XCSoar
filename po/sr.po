msgstr "Iskrena točka vjetra samo sa značkom."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:117
#, no-c-format
msgid "Full arrow"
msgstr "Puna strelica"

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:117
#, no-c-format
msgid "Draws an arrow head with a dashed arrow line."
msgstr "Iskrena točka vjetra sa priznaceno linijom."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:122
#, no-c-format
msgid "No SkyLines traffic is drawn."
msgstr "Nema iskrena trke u nebeskim putovima."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:123
#, no-c-format
msgid "Symbol"
msgstr "Simbol"

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:123
#, no-c-format

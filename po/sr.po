msgstr ""
"Minimalna visina na osnovu finish visine referencije (AGL ili MSL) pri "
"završetku zadatka. Postavite 0 za neograničen."

#: src/Dialogs/Settings/Panels/TaskRulesConfigPanel.cpp:99
#: src/Dialogs/Task/Manager/TaskPropertiesPanel.cpp:256

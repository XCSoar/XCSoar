msgstr "Veća jednostavna grafika."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:105
#, no-c-format
msgid "Detailed"
msgstr "Podrška za detaljnu vizualizaciju."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:106
#, no-c-format

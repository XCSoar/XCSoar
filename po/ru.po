msgstr "Изображает наземний трек в виде серой линии на карте."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:138
msgid "FLARM traffic"
msgstr "FLARM движение"

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:138

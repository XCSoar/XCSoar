#: src/Task/TypeStrings.cpp:32
#, no-c-format
msgid ""
"FAI rules, allows only FAI start, finish and turn point types, for badges "
"and records. Enables FAI finish height for final glide calculation."
msgstr ""
"FAI regler tillader kun FAI start, slut og vendepunkt typer. Aktiverer FAI "
"slut højde for slut glids beregning."

#: src/Task/TypeStrings.cpp:34
#, no-c-format
msgid "FAI rules, path from a start to two turn points and return."
msgstr "FAI regler, rute fra start til to vendepunkter og retur."

#: src/Task/TypeStrings.cpp:35
#, no-c-format
msgid "FAI rules, path from start to a single turn point and return."
msgstr "FAI regler, rute fra start til et enkelt vendepunkt og retur."

#: src/Task/TypeStrings.cpp:36
#, no-c-format
msgid "FAI rules, path from start to a goal destination."
msgstr "FAI regler, rute fra start til mål destination."

#: src/Task/TypeStrings.cpp:37
#, no-c-format
msgid ""
"Racing task around turn points. Can also be used for FAI badge and record "
"tasks. Allows all shapes of observation zones."
msgstr ""
"Racing opgave omkring vendepunkt. Kan også anvendes til FAI diplomer og "
"rekorder. Tillader alle former for observations zoner."

#: src/Task/TypeStrings.cpp:39
#, no-c-format
msgid ""
"Task through assigned areas, minimum task time applies. Restricted to "
"cylinder and sector observation zones."
msgstr ""
"Opgaver gennem tildelte områder, minimum opgave tid tæller. Begrænset til "
"cylinder og sektor observations zoner."

#: src/Task/TypeStrings.cpp:41
#, no-c-format
msgid ""
"Modified area task. Task with start, finish and at least one predefined 1 "
"mile cylinder. Pilot can add additional points as needed. Minimum task time "
"applies."
msgstr ""
"Modificeret områdeopgave. Opgave med start, afslutning og mindst en "
"foruddefineret cylinder med 1 miles radius. Pilot kan tilføje yderligere "
"punkter som nødvendigt. Minimumsopgavetid gælder."

#: src/Task/TypeStrings.cpp:42
#, no-c-format
msgid ""
"Racing task with a mix of assigned areas and turn points, minimum task time "
"applies."
msgstr ""
"Rask opgave med en kombination af udelag og vendepunkter, minimumsopgavetid "
"gælder."

#: src/Task/TypeStrings.cpp:43
#, no-c-format
msgid ""
"Casual touring task, uses start and finish cylinders and FAI sector turn "
"points."
msgstr ""
"Casual-touring opgave, bruger start- og afslutningscylindere og FAI-sektor-"
"vendepunkter."

#: src/Task/TypeStrings.cpp:56
#, no-c-format
msgid ""
"A 90-degree sector with 1 km radius. Cross corner edge from inside area to "
"start."
msgstr ""
"En 90-grader sektor med 1 km radius. Kryssér kanten fra indre område til "
"start."

#: src/Task/TypeStrings.cpp:57
#, no-c-format
msgid "A straight line start gate. Cross start gate from inside area to start."
msgstr ""
"Et rettighedsområde startgate. Kryssér startgate fra indre område til start."

#: src/Task/TypeStrings.cpp:58
#, no-c-format
msgid "A cylinder. Exit area to start."
msgstr "En cylinder. Udlæg område for at starte."

#: src/Task/TypeStrings.cpp:59
#, no-c-format
msgid ""
"A 90-degree sector with 'infinite' length sides. Cross any edge, scored from "
"corner point."
msgstr ""
"En 90-grader sektor med 'endelang' sider. Kryssér nogen kant, scoret fra "
"hjørnepunkt."

#: src/Task/TypeStrings.cpp:61
#, no-c-format
msgid "A keyhole. Scored from center."
msgstr "Et nøglehule. Scoret fra centrum."

#: src/Task/TypeStrings.cpp:62
#, no-c-format
msgid ""
"(German rules) Any point within 1/2 km of center or 10 km of a 90-degree "
"sector. Scored from center."
msgstr ""
"(Tyske regler) Hvert punkt inden for 1/2 km af centrum eller 10 km af en 90-"
"grader sektor. Scoret fra centrum."

#: src/Task/TypeStrings.cpp:64
#, no-c-format
msgid ""
"(British rules) Any point within 1/2 km of center or 20 km of a 90-degree "
"sector. Scored from center."
msgstr ""
"(Britiske regler) Hvert punkt inden for 1/2 km af centrum eller 20 km af en "
"90-grader sektor. Scoret fra centrum."

#: src/Task/TypeStrings.cpp:66
#, no-c-format
msgid ""
"(British rules) Any point within 1/2 km of center or 10 km of a 180-degree "
"sector. Scored from center."
msgstr ""
"(Britiske regler) Hvert punkt inden for 1/2 km af centrum eller 10 km af en "
"180-grader sektor. Scoret fra centrum."

#: src/Task/TypeStrings.cpp:68
#, no-c-format
msgid "A cylinder. Any point within area scored from center."
msgstr "En cylinder. Hvert punkt inden for område scoret fra centrum."

#: src/Task/TypeStrings.cpp:69
#, no-c-format
msgid "A 1 mile cylinder. Scored by farthest point reached in area."
msgstr ""
"En 1 miles cylinder. Scoret efter det mest udstrakte punkt nået inden for "
"område."

#: src/Task/TypeStrings.cpp:70
#, no-c-format
msgid "A cylinder. Scored by farthest point reached in area."
msgstr ""
"En cylinder. Scoret efter det mest udstrakte punkt nået inden for område."

#: src/Task/TypeStrings.cpp:71
#, no-c-format
msgid ""
"A sector that can vary in angle and radius. Scored by farthest point reached "
"inside area."
msgstr ""
"En sektor, der kan variere i vinkel og radius. Scoret efter det mest "
"udstrakte punkt nået inden for område."

#: src/Task/TypeStrings.cpp:73
#, no-c-format
msgid "A 90-degree sector with 1 km radius. Cross edge to finish."
msgstr "En 90-grader sektor med 1 km radius. Kryssér kant til afslutning."

#: src/Task/TypeStrings.cpp:74
#, no-c-format
msgid "Cross finish gate line into area to finish."
msgstr "Kryssér afslutningsgate linje ind i område for at afslutte."

#: src/Task/TypeStrings.cpp:75
#, no-c-format
msgid "Enter cylinder to finish."
msgstr "Indtræng cylinder for at afslutte."

#: src/Task/TypeStrings.cpp:76
#, no-c-format
msgid ""
"A 180-degree sector with 5 km radius. Exit area in any direction to start."
msgstr ""
"En 180-grader sektor med 5 km radius. Udlæg område i enhver retning til "
"start."

#: src/Task/TypeStrings.cpp:77
#, no-c-format
msgid ""
"A sector that can vary in angle, inner and outer radius. Scored by farthest "
"point reached inside area."
msgstr ""
"En sektor, der kan variere i vinkel, indre og udkant radius. Scoret efter "
"det mest udstrakte punkt nået inden for område."

#: src/Task/TypeStrings.cpp:79
#, no-c-format
msgid "A symmetric quadrant with a custom radius."
msgstr "Et symmetrisk kvadrant med en brugervendt radius."

#: src/Task/TypeStrings.cpp:80
#, no-c-format
msgid "A keyhole. Scored by farthest point reached in area."
msgstr "En nøglehule. Noteret efter den vidste punkt, der nås i området."


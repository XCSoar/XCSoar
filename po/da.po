msgstr ""
"Tidsbasert gennemsnitlig stigningshastighed i alle termiske luftstrømme."

#: src/InfoBoxes/Content/Factory.cpp:631
#, no-c-format
msgid "Task req. total height trend"
msgstr "Opgavereq. total højde tendens"

#: src/InfoBoxes/Content/Factory.cpp:632

#: src/Dialogs/Settings/Panels/AirspaceConfigPanel.cpp:158
msgid "Airspace display"
msgstr "Luftromvisning"

#: src/Dialogs/Settings/Panels/AirspaceConfigPanel.cpp:159
msgid ""
"Controls filtering of airspace for display and warnings. The airspace filter "
"button also allows filtering of display and warnings independently for each "
"airspace class."
msgstr ""
"Kontroller filter af luftrom for visning og varingsmeddelelser. "
"Luftromfilterknappen tillader også at filtere visning og varingsmeddelelser "
"uafhængigt for hvert luftromskab."

#: src/Dialogs/Settings/Panels/AirspaceConfigPanel.cpp:162

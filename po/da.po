#, no-c-format
msgid "Team bearing difference"
msgstr "Tjekkbearing forskel"

#: src/InfoBoxes/Content/Factory.cpp:576
#, no-c-format
msgid "Team BrngD"
msgstr "TjebearngD"

#: src/InfoBoxes/Content/Factory.cpp:577
#, no-c-format

msgstr "L/D variometer"

#: src/InfoBoxes/Content/Factory.cpp:544
#, no-c-format
msgid "L/D Vario"
msgstr "L/D Variometer"

#: src/InfoBoxes/Content/Factory.cpp:545
#, no-c-format
msgid ""

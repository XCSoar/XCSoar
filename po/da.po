msgstr ""
"Relativ kurs til placeringen af teamets fly ved den sidste rapporterede "
"tjekkodenummer."

#: src/InfoBoxes/Content/Factory.cpp:583
#, no-c-format
msgid "Team range"
msgstr "Tjekkrækkevidde"

#: src/InfoBoxes/Content/Factory.cpp:584
#, no-c-format
msgid "Team Dist"
msgstr "Tjedistans"


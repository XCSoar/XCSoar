#: src/Dialogs/Settings/Panels/WeGlideConfigPanel.cpp:73
msgid "Automatic Upload"
msgstr "Automatisch Hochladen"

#: src/Dialogs/Settings/Panels/WeGlideConfigPanel.cpp:74

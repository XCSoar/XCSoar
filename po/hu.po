msgstr "Középen"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:122
#, no-c-format
msgid "Center the status message boxes."
msgstr "Státusz dobozok középre igazítása."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:124
#, no-c-format
msgid "Show status message boxes in the top left corner."
msgstr "Az állapotjelző üzeneteket a bal felső sarokban jeleníti meg."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:130
#, no-c-format
msgid "Box"
msgstr "Keret"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:130
#, no-c-format
msgid "Draws boxes around each InfoBox."
msgstr "Keret megjelenítése mindegyik InfóDoboz körül."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:132
#, no-c-format
msgid "Tab"
msgstr "Fül"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:132
#, no-c-format
msgid "Draws a tab at the top of the InfoBox across the title."
msgstr "A InfóDobozok felső élére rajzolt fül."


msgstr "Üveg"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:142
#, no-c-format
msgid "Use the system-wide setting"
msgstr "A rendszeres beállítás használata"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:144
#, no-c-format
msgid "Black text on white background"
msgstr "Fekete szöveg fehér háttérre"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:146
#, no-c-format
msgid "White text on black background"
msgstr "Fehér szöveg kék háttérre"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:151
#, no-c-format
msgid "Follow global"
msgstr "Kövesse globálisan"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:152
#, no-c-format

msgstr "Oro trasas kaip mėlyna juosta žemėlapio."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:138
msgid "FLARM traffic"
msgstr "FLARM tarnavimas"

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:138
msgid "This enables the display of FLARM traffic on the map window."
msgstr "Tai leidžia apžvelgti FLARM tarnavimo žemėlapius."

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:141
msgid "Fade traffic"
msgstr "Pakelių vaizdas"

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:141

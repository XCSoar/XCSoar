msgstr "GR skrisimo režimas"

#: src/InfoBoxes/Content/Factory.cpp:159
#, no-c-format
msgid "GR Cruise"
msgstr "GR Skrydis"

#: src/InfoBoxes/Content/Factory.cpp:160
#, no-c-format
msgid ""

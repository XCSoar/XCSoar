msgid "Icons"
msgstr "Ikone"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:116
#, no-c-format
msgid "Show icons on tabbed dialogs."
msgstr "Rodyti ikonas įkurtų langelių dialoguose."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:121

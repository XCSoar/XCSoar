msgstr "Nurodo, kurie InfoBox'ai turėtų rodytis šiame puslapyje."

#: src/Dialogs/Settings/Panels/PagesConfigPanel.cpp:197
#, no-c-format
msgid ""
"For cruise mode. Displayed when 'Auto' is selected and glider is below final "
"glide altitude."
msgstr ""
"Laikotarpiškas režimas. Rodytas, kai 'Automatiškai' yra pasirinkta ir "

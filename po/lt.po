msgstr ""
"Termal pagalbos įjungti ir pasirinkti jo padėties nustatymo vietą "
"pagrindiniame ekrane."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:155
msgid "Thermal band"
msgstr "Termos juosta"

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:156

msgstr ""
"Không gian hàng không và địa hình không được sử dụng cho lập trình đường "
"bay."

#: src/Dialogs/Settings/Panels/RouteConfigPanel.cpp:86
#, no-c-format
msgid "Routes will avoid terrain."
msgstr "Đường bay sẽ tránh địa hình."

#: src/Dialogs/Settings/Panels/RouteConfigPanel.cpp:88
#, no-c-format

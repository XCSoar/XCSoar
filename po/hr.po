msgstr "Tijesto"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:136
#, no-c-format
msgid "Glass"
msgstr "Slikav"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:142
#, no-c-format
msgid "Use the system-wide setting"
msgstr "Koristi sustavnu postavku"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:144
#, no-c-format
msgid "Black text on white background"
msgstr "Crna tekst na bijelu pozadini"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:146
#, no-c-format
msgid "White text on black background"
msgstr "Bijeli tekst na crnoj pozadini"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:151
#, no-c-format
msgid "Follow global"
msgstr "Slijedite globalno"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:152
#, no-c-format
msgid "Use the same light/dark mode as the overall UI."
msgstr ""
"Koristite isti svijetli/tamni način rada kao cjelokupno korisničko sučelje."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:153
#, no-c-format
msgid "Light"
msgstr "Svjetlo"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:154
#, no-c-format
msgid "Always use dark text on a light InfoBox background."
msgstr "Uvijek koristite tamni tekst na svijetloj pozadini InfoBoxa."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:155
#, no-c-format
msgid "Dark"
msgstr "tamno"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:156
#, no-c-format
msgid "Always use light text on a dark InfoBox background."
msgstr "Uvijek koristite svijetli tekst na tamnoj pozadini InfoBoxa."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:179
msgid "Full screen"
msgstr "Cijela ekran"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:179
msgid "Run XCSoar in full screen mode"
msgstr "Pokreni XCSoar u cijeloukupnom režimu"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:184
msgid "Display orientation"
msgstr "Razdoblje prikaza"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:184
msgid "Rotate the display on devices that support it."
msgstr "Rotiraj zaslon na uređaju koji podržava to."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:189
msgid "Dark mode"
msgstr "Tjedna režim"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:193
msgid "InfoBox geometry"
msgstr "Geometrija infoboxa"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:194
msgid ""
"A list of possible InfoBox layouts. Do some trials to find the best for your "
"screen size."
msgstr ""
"Lista mogućih dizajnova InfoBox-a. Napravite nekoliko isprobavanja da "
"pronađete najbolji za veličinu vašeg zaslona."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:197
msgid "InfoBox title size"
msgstr "InfoBox nazivi"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:197
msgid "Zoom factor for InfoBox title and comment text"
msgstr "Faktor povećanja za naslov i komentarski tekst u InfoBox-u"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:202
msgid "Tab dialog style"
msgstr "Dijalogovski stil taba"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:205
msgid "Message display"
msgstr "Prikaz poruka"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:211
msgid "Colored InfoBoxes"
msgstr "Bojane InfoBox-ovi"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:212
msgid ""
"If true, certain InfoBoxes will have coloured text. For example, the active "
"waypoint InfoBox will be blue when the glider is above final glide."
msgstr ""
"Ako je to istinito, određeni InfoBox-ovi će imati bojano tekstu. Na primjer, "
"aktivna putna točka InfoBox-ov će biti plava kada jedrilica bude iznad "
"završnog kliza."


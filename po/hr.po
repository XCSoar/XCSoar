msgstr "Odrediti režim za prepoznavanje nadzora."

#: src/Dialogs/Settings/Panels/AirspaceConfigPanel.cpp:213
msgid "Airspace transparency"
msgstr "Nadzorna transparenija"

#: src/Dialogs/Settings/Panels/AirspaceConfigPanel.cpp:213

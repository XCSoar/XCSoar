msgstr "Kliknite da biste vidjeli cijeli put"

#: src/Dialogs/Settings/Panels/SiteConfigPanel.cpp:49
msgid "Map database"
msgstr "Bazu karti"

#: src/Dialogs/Settings/Panels/SiteConfigPanel.cpp:50
msgid ""

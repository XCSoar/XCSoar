#, no-c-format
msgid "Show status message boxes in the top left corner."
msgstr "Prikaži poručivanja stanja na gornjem lijevom kutu."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:130
#, no-c-format
msgid "Box"
msgstr "Okvir"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:130
#, no-c-format
msgid "Draws boxes around each InfoBox."
msgstr "Okvir za svaku Infobox."

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:132
#, no-c-format
msgid "Tab"
msgstr "Tab"

#: src/Dialogs/Settings/Panels/LayoutConfigPanel.cpp:132
#, no-c-format
msgid "Draws a tab at the top of the InfoBox across the title."
msgstr "Nacrtaj tab na vrhu InfoBox-a preko naslova."


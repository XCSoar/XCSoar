"displayed."
msgstr "Za način klip airspace, ovo je visina pod kojom prostor je prikazan."

#: src/Dialogs/Settings/Panels/AirspaceConfigPanel.cpp:172
msgid "Margin"
msgstr "Margina"

#: src/Dialogs/Settings/Panels/AirspaceConfigPanel.cpp:173

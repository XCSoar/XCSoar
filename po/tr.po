#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:95
#, no-c-format
msgid "Vario E-ink"
msgstr "Vario"

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:95
#, no-c-format

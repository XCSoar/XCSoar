#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:80
#, no-c-format
msgid "Vario #1"
msgstr "Varyometre #1"

#: src/Dialogs/Settings/Panels/SymbolsConfigPanel.cpp:80
#, no-c-format

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:69
#, no-c-format
msgid "Disable thermal assistant."
msgstr "Termik yardımcısını devre dışı bırak."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:72
#, no-c-format
msgid "Show thermal assistant in bottom left."
msgstr "Termik yardımcıyı sol altta göster."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:75
#, no-c-format
msgid ""
"Show thermal assistant in bottom left, above or to the right of InfoBoxes "
"(if present)."
msgstr ""
"Termik yardımcıyı sol altta göster, InfoBox(lar) varsa onların üstünde veya "
"sağında."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:78
#, no-c-format
msgid "Show thermal assistant in bottom right."
msgstr "Termik yardımcıyı sağ altta göster."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:81
#, no-c-format
msgid ""
"Show thermal assistant in bottom right, above or to the left of InfoBoxes "
"(if present)."
msgstr ""
"Termik yardımcıyı sağ altta göster, InfoBox(lar) varsa onların üstünde veya "
"sola."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:84
#, no-c-format
msgid "Show thermal assistant in top left."
msgstr "Termik yardımcıyı sol üstte göster."

#: src/Dialogs/Settings/Panels/GaugesConfigPanel.cpp:87
#, no-c-format

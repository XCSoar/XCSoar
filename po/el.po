msgstr "Απόσταση AAT γύρω από στόχο"

#: src/InfoBoxes/Content/Factory.cpp:528
#, no-c-format
msgid "AAT Dtgt"
msgstr "AAT Απ.Στ."

#: src/InfoBoxes/Content/Factory.cpp:529
#, no-c-format
msgid ""

msgstr "Επιπλέον θερμοκρασία ανέμου"

#: src/InfoBoxes/Content/Factory.cpp:889
#, no-c-format
msgid "Wind, head component (simplified)"
msgstr "Βαθμός αεροδυναμικής ροής"

#: src/InfoBoxes/Content/Factory.cpp:890
#, no-c-format
msgid "Head Wind *"
msgstr "Αεροδυναμική ροή *"

#: src/InfoBoxes/Content/Factory.cpp:891
#, no-c-format
msgid ""
"Current head wind component. The simplified head wind is calculated by "
"subtracting GPS ground speed from TAS if airspeed is available from an "
"external device."
msgstr ""
"Σημαντικότερη αεροδυναμική ροή, η οποία υπολογίζεται με την διαφορά μεταξύ "

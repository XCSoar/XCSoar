msgstr "Αληθινή ταχύτητα αέρος (V TAS) που αναφέρεται από έξυπνο variometer."

#: src/InfoBoxes/Content/Factory.cpp:559
#, no-c-format
msgid "Team code"
msgstr "Κωδικός Ομάδας"

#: src/InfoBoxes/Content/Factory.cpp:561
#, no-c-format

msgstr "Β ΤΑΣ"

#: src/InfoBoxes/Content/Factory.cpp:562
#, no-c-format
msgid "True Airspeed reported by a supported external intelligent vario."
msgstr ""
"Θετική ταχύτητα υψηλότερου περιθώριου διαμέρισης (TAS) αναφέρομαι από ένα "
"υποστηρίζοντα εξωτερικό βαριομέτρο."

#: src/InfoBoxes/Content/Factory.cpp:568
#, no-c-format
msgid "Team code"
msgstr "Κωδικός Ομάδας"

#: src/InfoBoxes/Content/Factory.cpp:570
#, no-c-format
msgid ""
"Current Team code for this aircraft. Use this to report to other team "

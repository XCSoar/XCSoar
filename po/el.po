#: src/InfoBoxes/Content/Factory.cpp:896
#, no-c-format
msgid "Task cruise efficiency"
msgstr "Επιπλέον ενεργειακή απόδοση"

#: src/InfoBoxes/Content/Factory.cpp:897
#, no-c-format

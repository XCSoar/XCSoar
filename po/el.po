#: src/InfoBoxes/Content/Factory.cpp:771
#, no-c-format
msgid "Vario trace"
msgstr "Μεταθέτημα βαριομέτρου"

#: src/InfoBoxes/Content/Factory.cpp:772
#, no-c-format

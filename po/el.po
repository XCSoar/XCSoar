msgstr "Ταχύτητα εδάφους"

#: src/InfoBoxes/Content/Factory.cpp:168
#, no-c-format
msgid "V GND"
msgstr "V ΝΤΡ"

#: src/InfoBoxes/Content/Factory.cpp:169
#, no-c-format
msgid ""

msgstr "Θερμική μέση"

#: src/InfoBoxes/Content/Factory.cpp:634
#, no-c-format
msgid "Time-average climb rate in all thermals."
msgstr "Μέση αύξηση συγκέντρωσης και χρόνου σε όλους τους θερμούς."

#: src/InfoBoxes/Content/Factory.cpp:640
#, no-c-format
